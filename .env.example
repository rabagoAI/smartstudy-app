# Firebase Configuration
# Obtén estos valores en Firebase Console -> Project Settings -> General
VITE_APP_FIREBASE_API_KEY=your_api_key_here
VITE_APP_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_APP_FIREBASE_PROJECT_ID=your_project_id
VITE_APP_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_APP_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_APP_FIREBASE_APP_ID=your_app_id
VITE_APP_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Gemini AI Config — SOLO para el servidor (Vercel Function), nunca en el cliente
# Obtén tu clave en Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin SDK — SOLO para el servidor (webhook, rate limiting)
# Genera el JSON en Firebase Console → Project Settings → Service Accounts → Generate new private key
# Pega todo el contenido del JSON como valor de esta variable (en una sola línea)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}

# Stripe — Pagos
# Dashboard de Stripe → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ID del precio del Plan Básico creado en Stripe → Products → Pricing
STRIPE_BASIC_PRICE_ID=price_...

# Clave pública de Stripe (para el frontend si se añade Stripe.js en el futuro)
VITE_STRIPE_PUBLIC_KEY=pk_live_...

# Google Analytics 4
VITE_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Generador de contenido (generar_tema.py) — SOLO para scripts de servidor ──
# API Key de Anthropic (Claude Haiku 4.5)
# Obtén tu clave en https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Firebase Admin SDK para el script Python
# Genera la clave en Firebase Console → Project Settings → Service Accounts → Generate new private key
# Guarda el archivo JSON descargado en la carpeta scripts/ (nunca commitear)
FIREBASE_CREDENTIALS_PATH=scripts/serviceAccountKey.json

# ID del proyecto Firebase (igual que VITE_APP_FIREBASE_PROJECT_ID)
FIREBASE_PROJECT_ID=your_project_id
